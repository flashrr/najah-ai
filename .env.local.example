# =============================================================
# Najah AI — Environment Variables
# Copy this file to .env.local and fill in your real values.
# Never commit .env.local to version control.
# =============================================================


# -------------------------------------------------------------
# REQUIRED
# The app will not start without these.
# -------------------------------------------------------------

# Your Supabase project URL (found in: Supabase → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL

# Supabase public anon key — safe to expose in the browser
# (found in: Supabase → Settings → API → Project API keys → anon / public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase service role key — server-only, never expose to the browser
# (found in: Supabase → Settings → API → Project API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Your OpenAI API key — used by the AI tutor (default provider)
# (found in: https://platform.openai.com/api-keys)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY


# -------------------------------------------------------------
# OPTIONAL
# These have working defaults in the code.
# Only set them if you want to override the default behaviour.
# -------------------------------------------------------------

# AI provider to use: "openai" (default) or "openrouter"
# AI_PROVIDER=openai

# AI model to use (default: gpt-4o-mini — fast and cost-effective)
# For OpenAI:    gpt-4o-mini | gpt-4o | gpt-3.5-turbo
# For OpenRouter: openai/gpt-4o-mini | anthropic/claude-3-haiku | etc.
# AI_MODEL=gpt-4o-mini

# OpenRouter API key — only needed if AI_PROVIDER=openrouter
# (found in: https://openrouter.ai/keys)
# OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
